# Copy to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — REQUIRED to delete users from Admin (Project Settings → API → service_role secret)
# SUPABASE_SERVICE_ROLE_KEY=

# Super admin email — promoted to super_admin on signup
SUPER_ADMIN_EMAIL=muhammadasadullah833@gmail.com

# Public site URL for auth email links (signup confirm, password reset).
# REQUIRED in production if not on Vercel, and REQUIRED for custom domains on Vercel.
# Must match Supabase Dashboard → Authentication → URL Configuration → Site URL.
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Google AI Studio → Gemini API key (server-only, super_admin AI audits)
GEMINI_API_KEY=
