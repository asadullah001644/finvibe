# Copy to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PIN lock — bcrypt hash of your 4–6 digit PIN (server-only, never expose the plain PIN)
# Generate: node -e "const bcrypt=require('bcryptjs'); bcrypt.hash('YOUR_PIN', 10).then(console.log)"
# Local .env.local: escape every $ as \$  e.g. \$2b\$10\$...
# Vercel: paste the raw hash (usually works without escaping)
APP_SECRET_PIN_HASH=

# Google AI Studio → Gemini API key (server-only)
GEMINI_API_KEY=
