# Copy to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — REQUIRED to delete users from Admin (Project Settings → API → service_role secret)
# SUPABASE_SERVICE_ROLE_KEY=

# Super admin email — promoted to super_admin on signup
SUPER_ADMIN_EMAIL=muhammadasadullah833@gmail.com

# Public site URL for auth emails (signup confirm, password reset).
# On Vercel the app auto-detects from the request host; set this if you use a custom domain.
# Do NOT set this to localhost in production.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google AI Studio → Gemini API key (server-only, super_admin AI audits)
GEMINI_API_KEY=
