# Copy to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — required for admin user delete (Project Settings → API → service_role)
# SUPABASE_SERVICE_ROLE_KEY=

# Super admin email — promoted to super_admin on signup
SUPER_ADMIN_EMAIL=muhammadasadullah833@gmail.com

# Optional — used in password reset emails (defaults to localhost or VERCEL_URL)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google AI Studio → Gemini API key (server-only, super_admin AI audits)
GEMINI_API_KEY=
