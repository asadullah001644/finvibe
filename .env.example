# Copy to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PIN lock — bcrypt hash of your 4–6 digit PIN (server-only, never expose the plain PIN)
# Generate hash + base64 (recommended for Vercel):
#   node -e "const bcrypt=require('bcryptjs'); bcrypt.hash('YOUR_PIN',10).then(h=>{console.log('HASH:',h);console.log('B64:',Buffer.from(h).toString('base64'))})"
#
# Local .env.local — escape every $ as \$:
#   APP_SECRET_PIN_HASH=\$2b\$10\$...
#
# Vercel (pick one):
#   APP_SECRET_PIN_HASH=$2b$10$...          (raw hash, no backslashes)
#   APP_SECRET_PIN_HASH_B64=...             (base64 of hash — safest on Vercel)
APP_SECRET_PIN_HASH=
# APP_SECRET_PIN_HASH_B64=

# Google AI Studio → Gemini API key (server-only)
GEMINI_API_KEY=
