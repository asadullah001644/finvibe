# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# local DB backups (financial data — never commit)
/backups/*
!/backups/.gitkeep

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets (.env.local stays local only)
.env*
!.env.example

# docs (not for public repo yet)
README.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
